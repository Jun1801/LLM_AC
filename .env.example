APP_ENV=dev
APP_POLICY_VERSION=2026-04-04

OPA_URL=http://localhost:8181
OPA_ENABLED=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai
VLLM_BASE_URL=http://localhost:8001/v1
LLM_INPUT_COST_PER_1M_TOKENS=0.15
LLM_OUTPUT_COST_PER_1M_TOKENS=0.60
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
VALIDATION_MODEL_ID=cross-encoder/ms-marco-MiniLM-L-6-v2
MODEL_DEVICE=cpu
MODEL_CACHE_DIR=
MODEL_LOCAL_FILES_ONLY=false
EMBEDDING_NORMALIZE=true
VALIDATION_THRESHOLD=0.80

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_ENABLED=false
QDRANT_SEMANTIC_COLLECTION=acl_semantic_cache_v2
QDRANT_ATTACK_COLLECTION=acl_attack_patterns_v2
QDRANT_VECTOR_SIZE=384

REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=false

OBJECT_STORE_BUCKET=acl-audit
OBJECT_STORE_ENABLED=false
